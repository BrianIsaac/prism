  "note": "Live surface snapshot documenting the 19-endpoint proxy. Documentation only — /prism/ does not read this at runtime. Every tool wrapper issues real HTTP calls against maps.grab.com.",
  "endpoints": [
    {
      "category": "search",
      "description": "Keyword POI search (no server-side radius/category/bounds)",
      "endpoint": "/api/v1/maps/poi/v1/search",
      "example": "/api/v1/maps/poi/v1/search?keyword=Marina+Bay&country=SGP&location=1.3521,103.8198&limit=10",
      "method": "GET",
      "query_params": ["keyword", "country", "location", "limit"],
      "upstream": "https://partner-api.grab.com/maps/poi/v1/search"
    },
    {
      "category": "search",
      "description": "Short-keyword POI autocomplete (debounce on client)",
      "endpoint": "/api/v1/maps/poi/v1/autocomplete",
      "example": "/api/v1/maps/poi/v1/autocomplete?keyword=mar&country=SGP",
      "method": "GET",
      "query_params": ["keyword", "country", "location", "limit"],
      "upstream": "https://partner-api.grab.com/maps/poi/v1/autocomplete"
    },
    {
      "category": "search",
      "description": "Reverse geocode (location as lat,lng)",
      "endpoint": "/api/v1/maps/poi/v1/reverse-geo",
      "example": "/api/v1/maps/poi/v1/reverse-geo?location=1.3521,103.8198",
      "method": "GET",
      "query_params": ["location"],
      "upstream": "https://partner-api.grab.com/maps/poi/v1/reverse-geo"
    },
    {
      "category": "search",
      "description": "Find Nearby Places V2 (radius in kilometres)",
      "endpoint": "/api/v1/maps/place/v2/nearby",
      "example": "/api/v1/maps/place/v2/nearby?location=1.3521,103.8198&radius=1&limit=10&rankBy=distance",
      "method": "GET",
      "query_params": ["location", "radius", "limit", "rankBy", "language"],
      "upstream": "https://partner-api.grab.com/maps/place/v2/nearby"
    },
    {
      "category": "routing",
      "description": "Route geometry for maps (polyline, legs, distance, duration); default coords lng,lat — use lat_first=true for lat,lng",
      "endpoint": "/api/v1/maps/eta/v1/direction",
      "example": "/api/v1/maps/eta/v1/direction?coordinates=103.8198,1.3521&coordinates=103.8501,1.2897&profile=driving&lat_first=false",
      "method": "GET",
      "query_params": ["coordinates", "profile", "lat_first", "overview", "geometries", "steps"],
      "upstream": "https://partner-api.grab.com/maps/eta/v1/direction"
    },
    {
      "category": "routing",
      "description": "Turn-by-turn / voice-oriented navigation (not the primary choice for map line geometry)",
      "endpoint": "/api/v1/maps/eta/v1/navigation",
      "example": "/api/v1/maps/eta/v1/navigation?coordinates=1.3521,103.8198&coordinates=1.2897,103.8501&profile=driving-car&lat_first=true",
      "method": "GET",
      "query_params": ["coordinates", "profile", "lat_first"],
      "upstream": "https://partner-api.grab.com/maps/eta/v1/navigation"
    },
    {
      "category": "traffic",
      "description": "Real-time traffic by bounding box",
      "endpoint": "/api/v1/traffic/real-time/bbox",
      "example": "/api/v1/traffic/real-time/bbox?lat1=1.4&lat2=1.2&lon1=103.6&lon2=104.0&linkReference=GRAB_WAY",
      "method": "GET",
      "note": "Our API also accepts bbox parameter (bbox=minLng,minLat,maxLng,maxLat) as convenience, which is converted to lat1/lat2/lon1/lon2 format internally.",
      "query_params": ["lat1", "lat2", "lon1", "lon2", "linkReference", "roadClass", "congestion"],
      "upstream": "https://partner-api.grab.com/maps/traffic/v1/real-time/bbox"
    },
    {
      "category": "traffic",
